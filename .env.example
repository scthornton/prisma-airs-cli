# ── LLM Provider ──────────────────────────────────────────────────────
# claude-api | claude-vertex | claude-bedrock | gemini-api | gemini-vertex | gemini-bedrock
LLM_PROVIDER=claude-api

# Claude API
ANTHROPIC_API_KEY=

# Google AI (Gemini API)
GOOGLE_API_KEY=

# Google Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Scan API ──────────────────────────────────────────────────────────
PANW_AI_SEC_API_KEY=

# ── Management API (OAuth2 client credentials) ──────────────────────
PANW_MGMT_CLIENT_ID=
PANW_MGMT_CLIENT_SECRET=
PANW_MGMT_TSG_ID=
# PANW_MGMT_ENDPOINT=https://api.sase.paloaltonetworks.com/aisec
# PANW_MGMT_TOKEN_ENDPOINT=https://auth.apps.paloaltonetworks.com/oauth2/access_token

# ── Tuning ───────────────────────────────────────────────────────────
SCAN_CONCURRENCY=5
# ACCUMULATE_TESTS=false
# MAX_ACCUMULATED_TESTS=

# ── Persistence ──────────────────────────────────────────────────────
# DATA_DIR=~/.prisma-airs/runs

# ── Memory ───────────────────────────────────────────────────────────
# MEMORY_ENABLED=true
# MEMORY_DIR=~/.prisma-airs/memory
# MAX_MEMORY_CHARS=3000

# ── DLP API (Data Loss Prevention) ────────────────────────────────
# Optional — overrides default DLP base URL (api.dlp.paloaltonetworks.com)
PANW_DLP_ENDPOINT=
